# ============================================================
# BASIC UTILITIES
# ============================================================

def get_app_timezone():
    try:
        return ZoneInfo(APP_TIMEZONE)
    except Exception:
        return timezone.utc


def normalize_symbol(symbol: str) -> str:
    s = symbol.upper().strip().replace("-", "/").replace(" ", "")

    if "/" in s:
        return s

    if len(s) == 6:
        return f"{s[:3]}/{s[3:]}"

    return symbol


def tf_interval(timeframe: str) -> str:
    timeframe = timeframe.lower().strip()

    if timeframe in ["1m", "1min", "1"]:
        return "1min"

    if timeframe in ["5m", "5min", "5"]:
        return "5min"

    return "1min"


def tf_seconds(timeframe: str) -> int:
    timeframe = timeframe.lower().strip()

    if timeframe in ["5m", "5min", "5"]:
        return 300

    return 60


def next_entry(timeframe: str) -> Dict[str, Any]:
    seconds = tf_seconds(timeframe)

    now = datetime.now(timezone.utc)
    now_ts = now.timestamp()

    entry_ts = math.floor(now_ts / seconds) * seconds + seconds
    entry_utc = datetime.fromtimestamp(entry_ts, tz=timezone.utc)
    expiry_utc = entry_utc + timedelta(seconds=seconds)

    tz = get_app_timezone()

    return {
        "entry_time": entry_utc.astimezone(tz).strftime("%H:%M:%S"),
        "expiry_time": expiry_utc.astimezone(tz).strftime("%H:%M:%S"),
        "countdown_seconds": max(0, int(entry_ts - now_ts)),
        "timezone": APP_TIMEZONE,
    }


def clamp_number(value: float, minimum: float, maximum: float) -> float:
    return max(minimum, min(maximum, value))


# ============================================================
# INDICATORS
# ============================================================

def ema(values: List[float], period: int) -> List[float]:
    if not values:
        return []

    k = 2 / (period + 1)
    result = []
    current = values[0]

    for value in values:
        current = value * k + current * (1 - k)
        result.append(current)

    return result


def rsi(closes: List[float], period: int = 14) -> float:
    if len(closes) < period + 1:
        return 50.0

    gains = []
    losses = []

    for i in range(1, len(closes)):
        change = closes[i] - closes[i - 1]
        gains.append(max(change, 0))
        losses.append(abs(min(change, 0)))

    avg_gain = sum(gains[-period:]) / period
    avg_loss = sum(losses[-period:]) / period

    if avg_loss == 0:
        return 100.0

    rs = avg_gain / avg_loss
    return 100 - (100 / (1 + rs))


def macd(closes: List[float]) -> Dict[str, float]:
    if len(closes) < 35:
        return {
            "macd": 0.0,
            "signal": 0.0,
            "histogram": 0.0,
        }

    ema12 = ema(closes, 12)
    ema26 = ema(closes, 26)

    macd_line = [a - b for a, b in zip(ema12, ema26)]
    signal_line = ema(macd_line, 9)

    value = macd_line[-1]
    signal_value = signal_line[-1]

    return {
        "macd": value,
        "signal": signal_value,
        "histogram": value - signal_value,
    }


# ============================================================
# TWELVEDATA REAL PROVIDER
# ============================================================

async def get_twelvedata_candles(
    symbol: str,
    timeframe: str,
    outputsize: int = 120,
) -> List[Dict[str, Any]]:
    if not TWELVEDATA_API_KEY:
        raise Exception("TWELVEDATA_API_KEY missing in .env")

    url = "https://api.twelvedata.com/time_series"

    params = {
        "symbol": normalize_symbol(symbol),
        "interval": tf_interval(timeframe),
        "outputsize": outputsize,
        "apikey": TWELVEDATA_API_KEY,
        "format": "JSON",
        "timezone": "UTC",
    }

    async with httpx.AsyncClient(timeout=25) as client:
        response = await client.get(url, params=params)

    data = response.json()

    if data.get("status") == "error":
        raise Exception(data.get("message", "TwelveData API error"))

    values = data.get("values", [])

    if not values:
        raise Exception(f"No candle data returned for {symbol}")

    candles = []

    for item in reversed(values):
        candles.append(
            {
                "time": item["datetime"],
                "open": float(item["open"]),
                "high": float(item["high"]),
                "low": float(item["low"]),
                "close": float(item["close"]),
            }
        )

    return candles


# ============================================================
# QUOTEX PROVIDER
# ============================================================

def quotex_timeframe_seconds(timeframe: str) -> int:
    timeframe = timeframe.lower().strip()

    if timeframe in ["5m", "5min", "5"]:
        return 300

    return 60


def normalize_quotex_asset(symbol: str) -> str:
    s = symbol.strip()

    if s in QUOTEX_ALIAS_MAP:
        return QUOTEX_ALIAS_MAP[s]

    def compact(value: str) -> str:
        return (
            value.upper()
            .replace("/", "")
            .replace("-", "")
            .replace(" ", "")
            .replace("(", "")
            .replace(")", "")
        )

    compact_input = compact(s)

    for label, actual in QUOTEX_ALIAS_MAP.items():
        if compact(label) == compact_input:
            return actual

    if s.endswith("_otc"):
        return s

    known_non_otc = {
        "CAC40",
        "FTSE100",
        "ASX200",
        "Nikkei225",
        "EuroStoxx50",
        "ChinaA50",
        "HK50",
        "IBEX35",
    }

    if s in known_non_otc:
        return s

    s = s.upper().replace("/", "").replace("-", "").replace(" ", "")

    return f"{s}_otc"


def quotex_is_demo() -> bool:
    return os.getenv("QUOTEX_IS_DEMO", "true").lower() == "true"


def quotex_env_ssid(is_demo: bool) -> Optional[str]:
    value = os.getenv("QUOTEX_SSID_DEMO") if is_demo else os.getenv("QUOTEX_SSID_LIVE")

    if value and value.strip():
        return value.strip()

    return None


async def quotex_maybe_await(value):
    if inspect.isawaitable(value):
        return await value
    return value


async def quotex_get_ssid(is_demo: bool):
    cache_key = "demo" if is_demo else "live"

    if QUOTEX_SSID_CACHE.get(cache_key):
        return QUOTEX_SSID_CACHE[cache_key]

    env_ssid = quotex_env_ssid(is_demo)

    if env_ssid:
        QUOTEX_SSID_CACHE[cache_key] = env_ssid
        return env_ssid

    email = os.getenv("QUOTEX_EMAIL")
    password = os.getenv("QUOTEX_PASSWORD")

    if not email or not password:
        raise Exception("Missing Quotex SSID or QUOTEX_EMAIL/QUOTEX_PASSWORD in .env")

    from api_quotex import get_ssid

    try:
        result = get_ssid(email=email, password=password)
    except TypeError:
        result = get_ssid(email, password)

    result = await quotex_maybe_await(result)

    ssid = None

    if isinstance(result, dict):
        ssid = result.get("demo") if is_demo else result.get("live")

        if not ssid:
            ssid = result.get("ssid")

        if not ssid and result.get("token"):
            demo_flag = 1 if is_demo else 0
            token = result.get("token")
            ssid = f'42["authorization",{{"session":"{token}","isDemo":{demo_flag},"tournamentId":0}}]'

    elif isinstance(result, tuple) and len(result) >= 2:
        success = result[0]
        data = result[1]

        if success and isinstance(data, dict):
            ssid = data.get("ssid")

            if not ssid and data.get("token"):
                demo_flag = 1 if data.get("is_demo", is_demo) else 0
                token = data.get("token")
                ssid = f'42["authorization",{{"session":"{token}","isDemo":{demo_flag},"tournamentId":0}}]'

    elif isinstance(result, str):
        ssid = result

    if not ssid:
        raise Exception("Could not get Quotex SSID")

    QUOTEX_SSID_CACHE[cache_key] = ssid

    return ssid


def quotex_row_value(row, keys, default=None):
    if isinstance(row, dict):
        lower_map = {str(k).lower(): v for k, v in row.items()}

        for key in keys:
            if key.lower() in lower_map:
                return lower_map[key.lower()]

    for key in keys:
        if hasattr(row, key):
            return getattr(row, key)

    return default


def parse_quotex_candles(raw_data, outputsize: int = 120):
    rows = []

    if hasattr(raw_data, "to_dict") and hasattr(raw_data, "columns"):
        rows = raw_data.to_dict("records")

    elif isinstance(raw_data, dict):
        if isinstance(raw_data.get("candles"), list):
            rows = raw_data["candles"]
        elif isinstance(raw_data.get("data"), list):
            rows = raw_data["data"]
        elif isinstance(raw_data.get("values"), list):
            rows = raw_data["values"]
        else:
            rows = [raw_data]

    elif isinstance(raw_data, list):
        rows = raw_data

    candles = []

    for row in rows:
        try:
            if hasattr(row, "model_dump"):
                row = row.model_dump()
            elif hasattr(row, "dict"):
                row = row.dict()

            if isinstance(row, dict) or hasattr(row, "__dict__"):
                time_value = quotex_row_value(
                    row,
                    ["time", "datetime", "timestamp", "from", "at", "created_at"],
                    datetime.now(timezone.utc).isoformat(),
                )

                open_value = quotex_row_value(row, ["open", "o"])
                close_value = quotex_row_value(row, ["close", "c"])
                high_value = quotex_row_value(row, ["high", "max", "h"])
                low_value = quotex_row_value(row, ["low", "min", "l"])

                if open_value is None or close_value is None:
                    continue

                open_float = float(open_value)
                close_float = float(close_value)

                high_float = (
                    float(high_value)
                    if high_value is not None
                    else max(open_float, close_float)
                )

                low_float = (
                    float(low_value)
                    if low_value is not None
                    else min(open_float, close_float)
                )

            elif isinstance(row, (list, tuple)) and len(row) >= 5:
                time_value = row[0]
                open_float = float(row[1])
                high_float = float(row[2])
                low_float = float(row[3])
                close_float = float(row[4])

            else:
                continue

            candles.append(
                {
                    "time": str(time_value),
                    "open": open_float,
                    "high": high_float,
                    "low": low_float,
                    "close": close_float,
                }
            )

        except Exception:
            continue

    return candles[-outputsize:]


async def quotex_call_candle_method(client, asset: str, period: int, outputsize: int):
    errors = []

    if hasattr(client, "get_candles"):
        try:
            result = client.get_candles(asset=asset, timeframe=period, count=outputsize)
            result = await quotex_maybe_await(result)
            candles = parse_quotex_candles(result, outputsize=outputsize)

            if len(candles) >= min(40, outputsize):
                return candles

            errors.append(f"get_candles parsed only {len(candles)} candles")
        except Exception as e:
            errors.append(f"get_candles error: {repr(e)}")

    if hasattr(client, "get_candles_dataframe"):
        try:
            result = client.get_candles_dataframe(asset=asset, timeframe=period, count=outputsize)
            result = await quotex_maybe_await(result)
            candles = parse_quotex_candles(result, outputsize=outputsize)

            if len(candles) >= min(40, outputsize):
                return candles

            errors.append(f"get_candles_dataframe parsed only {len(candles)} candles")
        except Exception as e:
            errors.append(f"get_candles_dataframe error: {repr(e)}")

    raise Exception("Could not fetch Quotex candles: " + " | ".join(errors))


class QuotexManager:
    """Manages a persistent Quotex connection to avoid slow connect/disconnect cycles."""
    def __init__(self):
        self.client = None
        self.last_ssid = None
        self.is_connecting = False
        self.lock = asyncio.Lock()

    async def get_client(self, ssid: str, is_demo: bool):
        async with self.lock:
            # Strip any accidental spaces/quotes
            ssid = ssid.strip().strip("'").strip('"')

            if self.client is None or self.last_ssid != ssid:
                if self.client:
                    try: await quotex_maybe_await(self.client.disconnect())
                    except: pass

                print(f"DEBUG: Connecting with token {ssid[:4]}...{ssid[-4:]}")
                from api_quotex import AsyncQuotexClient
                self.client = AsyncQuotexClient(ssid=ssid, is_demo=is_demo)
                self.last_ssid = ssid

                try:
                    connected = await asyncio.wait_for(quotex_maybe_await(self.client.connect()), timeout=55)
                    if not connected:
                        self.client = None
                        raise Exception("Connection Refused. Refresh SSID.")
                    print("DEBUG: Connected to Quotex successfully.")
                except Exception as e:
                    self.client = None
                    raise Exception(f"Handshake Failed: {e}")
            return self.client

QUOTEX_MANAGER = QuotexManager()

async def get_quotex_candles(asset: str, timeframe: str, outputsize: int = 120):
    if os.getenv("QUOTEX_ENABLED", "false").lower() != "true":
        raise Exception("QUOTEX_ENABLED is not true in .env")

    is_demo = quotex_is_demo()
    ssid = await quotex_get_ssid(is_demo)

    # Clean SSID
    ssid = ssid.strip()
    if (ssid.startswith("'") and ssid.endswith("'")) or (ssid.startswith('"') and ssid.endswith('"')):
        ssid = ssid[1:-1]
    ssid = ssid.replace("\\'", "'").replace('\\"', '"')

    asset = normalize_quotex_asset(asset)
    period = quotex_timeframe_seconds(timeframe)

    try:
        client = await QUOTEX_MANAGER.get_client(ssid, is_demo)

        print(f"DEBUG: Fetching {outputsize} candles for {asset}...")
        try:
            # Try up to 3 times to get candles if the connection is established
            for attempt in range(3):
                try:
                    candles = await asyncio.wait_for(
                        quotex_call_candle_method(client, asset, period, outputsize),
                        timeout=20
                    )
                    if candles and len(candles) >= 40:
                        print(f"DEBUG: Success! Got {len(candles)} candles on attempt {attempt+1}")
                        return candles
                except Exception as e:
                    print(f"DEBUG: Candle fetch attempt {attempt+1} failed: {e}")
                    if attempt < 2:
                        await asyncio.sleep(2)

            raise Exception("Failed to fetch candles after multiple attempts")

        except asyncio.TimeoutError:
            raise Exception("Timed out while fetching candle data (20s)")

    except Exception as e:
        # Reset manager on fatal error to force reconnect next time
        QUOTEX_MANAGER.client = None
        raise e





# ============================================================
# SIGNAL ENGINE
# ============================================================

def neutral_response(market_type: str, symbol: str, timeframe: str, reason: str):
    entry = next_entry(timeframe)

    return {
        "app": "TRADING MASTER",
        "market_type": market_type.upper(),
        "symbol": symbol,
        "timeframe": timeframe,
        "signal": "NEUTRAL",
        "confidence": 50,
        "score": 0,
        "entry_time": entry["entry_time"],
        "expiry_time": entry["expiry_time"],
        "countdown_seconds": entry["countdown_seconds"],
        "timezone": entry["timezone"],
        "price": None,
        "indicators": {},
        "reason": [reason],
        "disclaimer": "Signals are analysis only, not guaranteed financial advice.",
    }


def analyze(candles: List[Dict[str, Any]], market_type: str, symbol: str, timeframe: str):
    if len(candles) < 40:
        return neutral_response(market_type, symbol, timeframe, "Not enough candles for analysis.")

    try:
        closes = [float(c["close"]) for c in candles]
        opens = [float(c["open"]) for c in candles]
        highs = [float(c["high"]) for c in candles]
        lows = [float(c["low"]) for c in candles]
    except Exception:
        return neutral_response(market_type, symbol, timeframe, "Invalid candle format.")

    close = closes[-1]
    open_price = opens[-1]

    ema9_series = ema(closes, 9)
    ema21_series = ema(closes, 21)

    ema9_value = ema9_series[-1]
    ema21_value = ema21_series[-1]
    rsi_value = rsi(closes)
    macd_value = macd(closes)

    score = 0
    reasons = []

    recent_ranges = []

    for i in range(-10, 0):
        candle_range = highs[i] - lows[i]
        body_range = abs(closes[i] - opens[i])
        recent_ranges.append(max(candle_range, body_range))

    avg_range = sum(recent_ranges) / len(recent_ranges)

    if avg_range <= 0:
        return neutral_response(market_type, symbol, timeframe, "No useful volatility detected. Candle data may be flat.")

    if close > ema9_value and ema9_value >= ema21_value:
        score += 22
        reasons.append("EMA trend bullish")
    elif close < ema9_value and ema9_value <= ema21_value:
        score -= 22
        reasons.append("EMA trend bearish")
    elif close > ema21_value:
        score += 8
        reasons.append("Price above EMA21")
    elif close < ema21_value:
        score -= 8
        reasons.append("Price below EMA21")
    else:
        reasons.append("EMA trend mixed")

    ema9_slope = ema9_series[-1] - ema9_series[-5]

    if ema9_slope > 0:
        score += 10
        reasons.append("EMA slope bullish")
    elif ema9_slope < 0:
        score -= 10
        reasons.append("EMA slope bearish")
    else:
        reasons.append("EMA slope flat")

    if 57 <= rsi_value <= 75:
        score += 14
        reasons.append("RSI bullish")
    elif 50 < rsi_value < 57:
        score += 6
        reasons.append("RSI slightly bullish")
    elif 25 <= rsi_value <= 43:
        score -= 14
        reasons.append("RSI bearish")
    elif 43 < rsi_value < 50:
        score -= 6
        reasons.append("RSI slightly bearish")
    elif rsi_value > 75:
        score -= 8
        reasons.append("RSI overbought warning")
    elif rsi_value < 25:
        score += 8
        reasons.append("RSI oversold warning")
    else:
        reasons.append("RSI neutral")

    if macd_value["histogram"] > 0:
        score += 16
        reasons.append("MACD bullish")
    elif macd_value["histogram"] < 0:
        score -= 16
        reasons.append("MACD bearish")
    else:
        reasons.append("MACD neutral")

    if close > open_price:
        score += 8
        reasons.append("Last candle bullish")
    elif close < open_price:
        score -= 8
        reasons.append("Last candle bearish")
    else:
        reasons.append("Last candle neutral")

    last_range = max(highs[-1] - lows[-1], abs(close - open_price))

    if last_range > 0:
        body_ratio = abs(close - open_price) / last_range

        if body_ratio >= 0.55 and close > open_price:
            score += 8
            reasons.append("Strong bullish candle body")
        elif body_ratio >= 0.55 and close < open_price:
            score -= 8
            reasons.append("Strong bearish candle body")
        else:
            reasons.append("Weak candle body")

    change_3 = closes[-1] - closes[-4]
    change_5 = closes[-1] - closes[-6]

    if change_3 > 0:
        score += 10
        reasons.append("3-candle momentum bullish")
    elif change_3 < 0:
        score -= 10
        reasons.append("3-candle momentum bearish")
    else:
        reasons.append("3-candle momentum flat")

    if change_5 > 0:
        score += 8
        reasons.append("5-candle momentum bullish")
    elif change_5 < 0:
        score -= 8
        reasons.append("5-candle momentum bearish")
    else:
        reasons.append("5-candle momentum flat")

    bullish_count = 0
    bearish_count = 0

    for i in range(-5, 0):
        if closes[i] > opens[i]:
            bullish_count += 1
        elif closes[i] < opens[i]:
            bearish_count += 1

    if bullish_count >= 4:
        score += 8
        reasons.append("Bullish candle pressure")
    elif bearish_count >= 4:
        score -= 8
        reasons.append("Bearish candle pressure")
    else:
        reasons.append("Candle pressure mixed")

    previous_high = max(highs[-12:-1])
    previous_low = min(lows[-12:-1])

    if close > previous_high:
        score += 8
        reasons.append("Minor bullish breakout")
    elif close < previous_low:
        score -= 8
        reasons.append("Minor bearish breakout")

    market_upper = market_type.upper()

    if market_upper == "OTC":
        signal_threshold = 28
    else:
        signal_threshold = 35

    if score >= signal_threshold:
        signal_value = "CALL"
        confidence = clamp_number(58 + abs(score) * 0.55, 65, 94)
    elif score <= -signal_threshold:
        signal_value = "PUT"
        confidence = clamp_number(58 + abs(score) * 0.55, 65, 94)
    else:
        signal_value = "NEUTRAL"
        confidence = clamp_number(50 + abs(score) * 0.35, 50, 64)

    entry = next_entry(timeframe)

    return {
        "app": "TRADING MASTER",
        "market_type": market_upper,
        "symbol": symbol,
        "timeframe": timeframe,
        "signal": signal_value,
        "confidence": round(confidence, 2),
        "score": score,
        "entry_time": entry["entry_time"],
        "expiry_time": entry["expiry_time"],
        "countdown_seconds": entry["countdown_seconds"],
        "timezone": entry["timezone"],
        "price": close,
        "indicators": {
            "ema9": round(ema9_value, 6),
            "ema21": round(ema21_value, 6),
            "rsi": round(rsi_value, 2),
            "macd": round(macd_value["macd"], 6),
            "macd_signal": round(macd_value["signal"], 6),
            "macd_histogram": round(macd_value["histogram"], 6),
        },
        "strategy": {
            "name": "TRADING MASTER AI v1.0",
            "indicators_used": [
                "EMA 9",
                "EMA 21",
                "RSI 14",
                "MACD 12/26/9",
                "Candle Body",
                "Volatility Filter",
                "Momentum 3/5",
                "Mini Breakout",
            ],
            "market_type": market_upper,
            "timeframe": timeframe,
        },
        "chart": {
            "closes": [round(x, 6) for x in closes[-50:]],
            "opens": [round(x, 6) for x in opens[-50:]],
            "highs": [round(x, 6) for x in highs[-50:]],
            "lows": [round(x, 6) for x in lows[-50:]],
        },
        "reason": reasons,
        "disclaimer": "Signals are analysis only, not guaranteed financial advice.",
    }


