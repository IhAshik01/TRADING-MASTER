@app.get("/debug-otc")
async def debug_otc(symbol: str = Query("USDBRL_otc"), timeframe: str = Query("1m")):
    try:
        candles = await get_quotex_candles(asset=symbol, timeframe=timeframe, outputsize=120)

        closes = [float(c["close"]) for c in candles]
        opens = [float(c["open"]) for c in candles]
        highs = [float(c["high"]) for c in candles]
        lows = [float(c["low"]) for c in candles]

        ranges = [highs[i] - lows[i] for i in range(len(candles))]
        bodies = [abs(closes[i] - opens[i]) for i in range(len(candles))]

        flat_candles = 0

        for c in candles:
            if float(c["open"]) == float(c["high"]) == float(c["low"]) == float(c["close"]):
                flat_candles += 1

        analysis = analyze(candles, "OTC", symbol, timeframe)

        return {
            "ok": True,
            "symbol": symbol,
            "timeframe": timeframe,
            "candle_count": len(candles),
            "first_candle": candles[0],
            "last_candle": candles[-1],
            "last_10_candles": candles[-10:],
            "unique_counts": {
                "opens": len(set(round(c, 10) for c in opens)),
                "highs": len(set(round(c, 10) for c in highs)),
                "lows": len(set(round(c, 10) for c in lows)),
                "closes": len(set(round(c, 10) for c in closes)),
            },
            "flat_candles": flat_candles,
            "range_stats": {
                "min_range": min(ranges),
                "max_range": max(ranges),
                "avg_range": sum(ranges) / len(ranges),
                "avg_body": sum(bodies) / len(bodies),
            },
            "analysis": analysis,
        }

    except Exception as e:
        return {
            "ok": False,
            "error": str(e),
            "error_repr": repr(e),
            "error_type": type(e).__name__,
        }


@app.get("/quotex-raw")
async def quotex_raw(
    symbol: str = Query("USDBRL_otc"),
    timeframe: str = Query("1m"),
    count: int = Query(5),
):
    try:
        from api_quotex import AsyncQuotexClient

        is_demo = quotex_is_demo()
        ssid = await quotex_get_ssid(is_demo)

        asset = normalize_quotex_asset(symbol)
        period = quotex_timeframe_seconds(timeframe)

        client = AsyncQuotexClient(ssid=ssid, is_demo=is_demo)

        try:
            connected = client.connect()
            connected = await quotex_maybe_await(connected)

            if connected is False:
                raise Exception("Could not connect to Quotex websocket")

            raw = client.get_candles(asset=asset, timeframe=period, count=count)
            raw = await quotex_maybe_await(raw)

            if isinstance(raw, list):
                preview = [safe_preview_item(x) for x in raw[:count]]
            else:
                preview = safe_preview_item(raw)

            parsed = parse_quotex_candles(raw, outputsize=count)

            return {
                "ok": True,
                "symbol": symbol,
                "asset_used": asset,
                "timeframe": timeframe,
                "period": period,
                "raw_type": str(type(raw)),
                "raw_preview": preview,
                "parsed_count": len(parsed),
                "parsed_preview": parsed,
            }

        finally:
            try:
                result = client.disconnect()
                await quotex_maybe_await(result)
            except Exception:
                pass

    except Exception as e:
        return {
            "ok": False,
            "error": str(e),
            "error_repr": repr(e),
            "error_type": type(e).__name__,
        }


@app.get("/quotex-live-assets")
