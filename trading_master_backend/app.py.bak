def safe_preview_item(item):
    try:
        if isinstance(item, dict):
            return item
        if hasattr(item, "model_dump"):
            return item.model_dump()
        if hasattr(item, "dict"):
            return item.dict()
        if hasattr(item, "__dict__"):
            return item.__dict__
        return str(item)
    except Exception:
        return str(item)


